generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Local development only. Production deployments use ../schema.prisma.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Venue {
  id        String   @id @default(cuid())
  name      String
  city      String
  venueType String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dailyMetrics     DailyMetric[]
  weekdayMetrics   WeekdayMetric[]
  forecasts        Forecast[]
  bookingInquiries BookingInquiry[]
  venueRules       VenueRule[]
  packages         Package[]
  managerBriefings ManagerBriefing[]

  @@unique([name, city])
  @@index([city])
  @@index([venueType])
}

model DailyMetric {
  id                   String   @id @default(cuid())
  venueId              String
  date                 DateTime
  guestsCurrentYear    Int
  guestsPreviousYear   Int
  guestsDiff           Int
  bookingsCurrentYear  Int
  bookingsPreviousYear Int
  bookingsDiff         Int
  source               String
  createdAt            DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, date])
  @@index([venueId, date])
}

model WeekdayMetric {
  id                   String   @id @default(cuid())
  venueId              String
  weekday              Int
  bookingsCurrentYear  Int
  bookingsPreviousYear Int
  bookingsDiff         Int
  guestsCurrentYear    Int
  guestsPreviousYear   Int
  guestsDiff           Int
  source               String
  createdAt            DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, weekday])
  @@index([venueId, weekday])
}

model Forecast {
  id                 String   @id @default(cuid())
  venueId            String
  date               DateTime
  expectedGuests     Int
  expectedBookings   Int
  confidence         String
  demandLevel        String
  explanation        String
  recommendedActions String
  createdAt          DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, date])
  @@index([venueId, date])
}

model BookingInquiry {
  id               String    @id @default(cuid())
  venueId          String
  rawMessage       String
  customerName     String?
  customerEmail    String?
  customerPhone    String?
  requestedDate    DateTime?
  requestedTime    String?
  partySize        Int?
  intent           String?
  activityType     String?
  foodInterest     String?
  eventType        String?
  urgency          String?
  revenuePotential String?
  status           String    @default("new")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  venue    Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  aiDrafts AIDraft[]

  @@index([venueId, status])
  @@index([venueId, requestedDate])
}

model AIDraft {
  id                  String   @id @default(cuid())
  inquiryId           String
  suggestedReply      String
  internalSummary     String
  recommendedActions  String
  requiresHumanReview Boolean  @default(true)
  riskLevel           String
  status              String   @default("pending_review")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  inquiry BookingInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId, status])
}

model VenueRule {
  id        String   @id @default(cuid())
  venueId   String
  key       String
  value     String
  category  String
  updatedAt DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, key])
  @@index([venueId, category])
}

model Package {
  id               String  @id @default(cuid())
  venueId          String
  name             String
  description      String
  minGuests        Int?
  maxGuests        Int?
  priceDescription String
  active           Boolean @default(true)

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, name])
  @@index([venueId, active])
}

model ManagerBriefing {
  id                         String   @id @default(cuid())
  venueId                    String
  weekStartDate              DateTime
  weekEndDate                DateTime
  providerMode               String
  executiveSummary           String
  expectedDemand             String
  busiestUpcomingDays        String
  quietestUpcomingDays       String
  staffingRecommendations    String
  promotionRecommendations   String
  packageUpsellOpportunities String
  risksOrUnusualPatterns     String
  suggestedManagerActions    String
  sourceSnapshot             String
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, weekStartDate])
  @@index([venueId, createdAt])
}
